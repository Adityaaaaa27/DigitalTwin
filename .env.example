# ── Environment Variables ────────────────────────────────────────────────────
# Copy this file to `.env` and adjust values as needed.
#
# LOCAL DEVELOPMENT
# Just run: uvicorn main:app --reload
# ─────────────────────────────────────────────────────────────────────────────

# SQLite path
SQLITE_PATH=./mental_health.db

# ── Bayesian Model ───────────────────────────────────────────────────────────
LOW_THRESHOLD=3.5
HIGH_THRESHOLD=6.5
TREND_WINDOW=5
FUTURE_STEPS=3
ALERT_CONSECUTIVE_INCREASE=3

